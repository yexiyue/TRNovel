{
  "schema": "trnovel-booksource/v2",
  "name": "哔哩小说",
  "group": "测试",
  "url": "https://www.bilixs.com",
  "http": {
    "headers": {
      "User-Agent": "Mozilla/5.0 (Linux; Android 13; Pixel 7) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Mobile Safari/537.36",
      "Referer": "https://www.bilixs.com/",
      "Accept-Language": "zh-CN,zh;q=0.9"
    },
    "warmup": [
      "https://www.bilixs.com/"
    ],
    "charset": "auto",
    "fetcher": "auto",
    "timeout": 15000,
    "retry": {
      "max": 2,
      "backoffMs": 500
    }
  },
  "search": {
    "request": {
      "url": "{{base}}/search.html?searchkey={{key}}"
    },
    "list": {
      "via": "css",
      "select": ".module-search-item"
    },
    "item": {
      "bookUrl": {
        "via": "css",
        "select": "h3 a",
        "extract": {
          "attr": "href"
        }
      },
      "name": {
        "via": "css",
        "select": "h3 a",
        "extract": "text"
      },
      "cover": {
        "via": "css",
        "select": ".module-item-pic img",
        "extract": {
          "attr": "data-src"
        }
      },
      "author": {
        "via": "css",
        "select": ".novel-author",
        "extract": "text"
      },
      "kind": {
        "via": "css",
        "select": ".novel-serial",
        "extract": "text"
      },
      "lastChapter": {
        "via": "css",
        "select": ".novel-latestchapter a",
        "extract": "text"
      },
      "intro": {
        "via": "css",
        "select": ".novel-desc",
        "extract": "text"
      }
    }
  },
  "explore": {
    "entries": [
      {
        "fetch": {
          "request": {
            "url": "{{base}}/"
          },
          "list": {
            "via": "css",
            "select": ".nav-menu-items a[href*='lastupdate']"
          },
          "item": {
            "title": {
              "via": "css",
              "select": "span",
              "extract": "text"
            },
            "vars": {
              "category": {
                "via": "css",
                "select": "a",
                "extract": {
                  "attr": "href"
                },
                "clean": [
                  {
                    "regex": ".+/lastupdate_0_(\\d+).*",
                    "replace": "$1"
                  }
                ]
              }
            }
          }
        }
      }
    ],
    "page": {
      "request": {
        "url": "{{base}}/book/lastupdate_0_{{category}}_0_0_0_0_0_{{page}}_0.html"
      },
      "list": {
        "via": "css",
        "select": ".module-item"
      },
      "item": {
        "bookUrl": {
          "via": "css",
          "select": ".module-item-title",
          "extract": {
            "attr": "href"
          }
        },
        "name": {
          "via": "css",
          "select": ".module-item-title",
          "extract": "text"
        },
        "author": {
          "via": "css",
          "select": ".module-item-text",
          "extract": "text"
        },
        "cover": {
          "via": "css",
          "select": ".module-item-pic img",
          "extract": {
            "attr": "data-src"
          }
        }
      }
    }
  },
  "bookInfo": {
    "name": {
      "via": "css",
      "select": "[property=\"og:novel:book_name\"]",
      "extract": {
        "attr": "content"
      }
    },
    "author": {
      "via": "css",
      "select": "[property=\"og:novel:author\"]",
      "extract": {
        "attr": "content"
      }
    },
    "cover": {
      "via": "css",
      "select": "[property=\"og:image\"]",
      "extract": {
        "attr": "content"
      }
    },
    "intro": {
      "via": "css",
      "select": "[property=\"og:description\"]",
      "extract": {
        "attr": "content"
      },
      "clean": [
        {
          "regex": "<br\\s*/?>",
          "replace": "\n"
        },
        {
          "trim": true
        }
      ]
    },
    "kind": {
      "concat": [
        {
          "via": "css",
          "select": "[property=\"og:novel:tags\"]",
          "extract": {
            "attr": "content"
          }
        },
        {
          "via": "css",
          "select": "[property=\"og:novel:status\"]",
          "extract": {
            "attr": "content"
          }
        }
      ],
      "join": " · "
    },
    "lastChapter": {
      "via": "css",
      "select": "[property=\"og:novel:latest_chapter_name\"]",
      "extract": {
        "attr": "content"
      }
    },
    "tocUrl": {
      "via": "css",
      "select": "[property=\"og:novel:read_url\"]",
      "extract": {
        "attr": "content"
      }
    },
    "wordCount": {
      "firstOf": [
        {
          "via": "css",
          "select": ".novel-info-aux span.tag-link",
          "extract": "text",
          "clean": [
            {
              "regex": "\\s",
              "replace": ""
            }
          ]
        },
        {
          "via": "css",
          "select": "span.tag-link",
          "extract": "text",
          "clean": [
            {
              "regex": "\\s",
              "replace": ""
            }
          ]
        }
      ]
    }
  },
  "toc": {
    "list": {
      "via": "css",
      "select": ".box > h2.module-title.type, .box a.module-row-text"
    },
    "name": {
      "firstOf": [
        {
          "via": "css",
          "select": ".module-row-title",
          "extract": "text"
        },
        {
          "via": "css",
          "select": "h2",
          "extract": "text"
        }
      ]
    },
    "url": {
      "via": "css",
      "select": "a",
      "extract": {
        "attr": "href"
      }
    },
    "isVolume": {
      "via": "css",
      "select": "h2",
      "extract": "text"
    },
    "maxPages": 1
  },
  "content": {
    "value": {
      "via": "css",
      "select": ".article-content",
      "extract": "html",
      "clean": [
        {
          "regex": "请收藏本站[^<\\n]*",
          "replace": ""
        },
        {
          "trim": true
        }
      ]
    },
    "maxPages": 50
  },
  "samples": [
    {
      "bookUrl": "/novel/guzhenren.html",
      "expect": {
        "name": "蛊真人",
        "volumes": 8,
        "minChapters": 2000,
        "minContentChars": 500
      }
    }
  ]
}
