  },
  "explore": {
    "categories": [
      {
        "title": "推荐",
        "url": {
          "template": "{{base}}/"
        }
      }
    ],
    "list": {
      "via": "css",
      "select": ".muye-bottom-choiceness-item"
    },
    "item": {
      "name": {
        "via": "css",
        "select": ".title",
        "extract": "text"
      },
      "author": {
        "via": "css",
        "select": ".author",
        "extract": "text"
      },
      "cover": {
        "via": "css",
        "select": ".book-cover-img",
        "extract": {
          "attr": "src"
        },
        "clean": [
          {
            "prepend": "https:"
          }
        ]
      },
      "bookUrl": {
        "via": "css",
        "select": "a",
        "extract": {
          "attr": "href"
        }
      }
    }
  },
  "bookInfo": {
    "name": {
      "via": "css",
      "select": ".info-name",
      "extract": "text"
    },
    "author": {
      "via": "regex",
      "select": "\"author\":\\[\\{\"@type\":\"Person\",\"name\":\"([^\"]+)\""
    },
    "cover": {
      "via": "css",
      "select": ".book-cover-img",
      "extract": {
        "attr": "src"
      },
      "clean": [
        {
          "prepend": "https:"
        }
      ]
    },
    "intro": {
      "via": "css",
      "select": ".page-abstract-content",
      "extract": "text"
    },
    "kind": {
      "via": "css",
      "select": ".info-label",
      "extract": "text"
    },
    "wordCount": {
      "via": "regex",
      "select": "\"wordNumber\":(\\d+)",
      "clean": [
        {
          "append": " 字"
        }
      ]
    },
    "lastChapter": {
      "via": "regex",
      "select": "\"lastChapterTitle\":\"([^\"]+)\""
    },
    "tocUrl": {
      "via": "regex",
      "select": "/page/(\\d+)",
      "clean": [
        {
          "prepend": "https://fanqienovel.com/api/reader/directory/detail?bookId="
        }
      ]
    }
  },
  "toc": {
    "list": {
      "via": "json",
      "select": "$.data.chapterListWithVolume[*][*]"
    },
    "name": {
      "via": "json",
      "select": "$.title"
    },
    "url": {
      "concat": [
        {
          "literal": "https://fanqienovel.com/reader/"
        },
        {
          "via": "json",
          "select": "$.itemId"
        }
      ]
    },
    "maxPages": 1
  },
  "content": {
    "value": {
      "via": "css",
      "select": ".muye-reader-content",
      "extract": "html",
      "clean": [
        {
          "fontMap": "content"
        },
        {
          "trim": true
        }
      ]
    },
    "maxPages": 1
  },
  "samples": [
    {
      "bookUrl": "https://fanqienovel.com/page/7143038691944959011",
      "expect": {
        "name": "十日终焉",
        "minChapters": 1000,
        "minContentChars": 1000
      }
    }
  ],
  "search": {
    "request": {
      "url": {
        "template": "{{base}}/search/{{key}}"
      },
      "method": "GET",
      "render": true,
      "interceptApi": "search_book/v1"
    },
    "list": {
      "via": "json",
      "select": "$.data.search_book_data_list[*]"
    },
    "item": {
      "bookUrl": {
        "concat": [
          {
            "literal": "https://fanqienovel.com/page/"
          },
          {
            "via": "json",
            "select": "$.book_id"
          }
        ]
      },
      "name": {
        "via": "json",
        "select": "$.book_name",
        "clean": [
          {
            "fontMap": "search"
          }
        ]
      },
      "author": {
        "via": "json",
        "select": "$.author",
        "clean": [
          {
            "fontMap": "search"
          }
        ]
      },
      "cover": {
        "via": "json",
        "select": "$.thumb_url"
      },
      "kind": {
        "via": "json",
        "select": "$.category"
      }
    }
  }
}